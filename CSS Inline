* {

  box-sizing: border-box;

}

.slider {

  -webkit-appearance: none;

  appearance: none;

  width: 100%;

  height: 15px;

  background: #D3D3D3;

  outline: none;

  opacity: 0.7;

  -webkit-transition: .2s;

  transition: opacity .2s;

}

 

.slider:hover {

  opacity: 1;

}

 

.slider::-webkit-slider-thumb {

  -webkit-appearance: none;

  appearance: none;

  width: 10px;

  height: 25px;

  background: blue;

  cursor: pointer;

   

}

 

.slider::-moz-range-thumb {

  width: 10px;

  height: 25px;

  background: blue;

  cursor: pointer;

}

 

.sliderticks {

  display: none;

  justify-content: space-between;

  padding: 0 5px;

}

 

.sliderticks p {

  position: relative;

  display: flex;

  justify-content: center;

  text-align: center;

  width: 1px;

  background: #D3D3D3 ;

  height: 5px;

  line-height: 10px;

  margin: 0 0 20px 0;

}
